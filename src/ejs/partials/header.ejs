<header class="site-header border-bottom bg-white sticky-top">
  <nav class="navbar navbar-expand-lg" aria-label="主要導覽">
    <div class="container">
      <a class="navbar-brand fw-bold text-primary" href="./index.html"><%= site.name %></a>

      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#mainNavbar"
        aria-controls="mainNavbar"
        aria-expanded="false"
        aria-label="切換導覽選單"
      >
        <span class="navbar-toggler-icon"></span>
      </button>

      <div class="collapse navbar-collapse" id="mainNavbar">
        <ul class="navbar-nav ms-auto mb-2 mb-lg-0">
          <% navItems.forEach((item) => { %>
            <li class="nav-item">
              <a
                class="nav-link <%= page.key === item.key ? 'active' : '' %>"
                href="<%= item.href %>"
                <%= page.key === item.key ? 'aria-current="page"' : '' %>
              >
                <%= item.label %>
              </a>
            </li>
          <% }) %>
        </ul>
      </div>
    </div>
  </nav>
</header>
